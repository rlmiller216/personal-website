# Notion API
NOTION_API_KEY=ntn_your_api_key_here
# Data Source IDs (v5 API uses dataSources.query, not databases.query)
NOTION_PROJECTS_DS_ID=your_projects_data_source_id
NOTION_TOOLS_DS_ID=your_tools_data_source_id
NOTION_RESOURCES_DS_ID=your_resources_data_source_id
NOTION_INTERESTS_PAGE_ID=your_interests_parent_page_id
NOTION_ABOUT_PAGE_ID=your_about_page_id

# Site Metadata (displayed in nav, hero, footer — never hardcode in templates)
SITE_NAME=Rebecca Miller
SITE_TAGLINE=Scientist committed to the greater good
SITE_HERO_HEADLINE=Science for the greater good
SITE_HERO_INTRO=PhD Biophysicist building tools for a better world
